# All of these are optional for running the app day-to-day — the app
# itself never talks to Supabase or any cloud host at runtime. They're
# only needed for the one-time maintainer task of re-seeding the local
# catalog (universities/faculties/departments/courses/past_questions)
# from the reference Supabase project.

# Seed-time only (scripts/fetch-seed-data.ts). Never imported by app
# runtime code — see src/lib/prisma.ts, which only ever reads DATABASE_URL.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Local SQLite path. Default (file:./data/grinnish.db) is fine for
# everyone; only override if you need the DB somewhere else.
DATABASE_URL=file:./data/grinnish.db

# Local Ollama endpoint. Default is fine unless Ollama is running on a
# different host/port.
OLLAMA_URL=http://localhost:11434
