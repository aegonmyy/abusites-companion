# None of these are needed to run the app, or even to set it up — the
# default `npm run seed` loads the course/past-questions catalog from the
# git-committed static bundle at prisma/seed-bundle/catalog.json, with zero
# credentials and zero network calls. The app itself never talks to
# Supabase or any cloud host at runtime.
#
# The two Supabase-related vars below are ONLY for the maintainer task of
# periodically refreshing that bundle from the reference Supabase project
# (see README "Refreshing the bundled seed data"). Normal end users never
# need these and should leave them blank.

# Maintainer-only, refresh-time only (scripts/fetch-seed-data.ts,
# scripts/reseed-direct.ts). Never imported by app runtime code — see
# src/lib/prisma.ts, which only ever reads DATABASE_URL.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# DIRECT_DB_URL=   # direct Postgres superuser connection string; never commit a real value

# Local SQLite path. Default (file:./data/grinnish.db) is fine for
# everyone; only override if you need the DB somewhere else.
DATABASE_URL=file:./data/grinnish.db

# Local Ollama endpoint. Default is fine unless Ollama is running on a
# different host/port.
OLLAMA_URL=http://localhost:11434
