// Grinnish Local — Prisma schema (SQLite via better-sqlite3 driver adapter)
// See prisma.config.ts for the datasource URL and generated client output.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Catalog tables — mirror the five Supabase source tables (UUIDs as TEXT,
// FKs preserved). Populated by scripts/fetch-seed-data.ts. Read-only at
// runtime; the app never writes to these.
// ---------------------------------------------------------------------------

model University {
  id         String       @id
  name       String
  country    String?
  city       String?
  createdAt  DateTime?    @map("created_at")
  updatedAt  DateTime?    @map("updated_at")
  faculties  Faculty[]
  courses    Course[]

  @@map("universities")
}

model Faculty {
  id           String       @id
  universityId String       @map("university_id")
  name         String
  createdAt    DateTime?    @map("created_at")
  updatedAt    DateTime?    @map("updated_at")
  university   University   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  departments  Department[]

  @@index([universityId])
  @@map("faculties")
}

model Department {
  id        String    @id
  facultyId String    @map("faculty_id")
  name      String
  createdAt DateTime? @map("created_at")
  updatedAt DateTime? @map("updated_at")
  faculty   Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  courses   Course[]

  @@index([facultyId])
  @@map("departments")
}

model Course {
  id            String         @id
  departmentId  String?        @map("department_id")
  universityId  String?        @map("university_id")
  code          String
  title         String
  createdAt     DateTime?      @map("created_at")
  updatedAt     DateTime?      @map("updated_at")
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  university    University?    @relation(fields: [universityId], references: [id], onDelete: SetNull)
  pastQuestions PastQuestion[]

  @@index([departmentId])
  @@index([universityId])
  @@map("courses")
}

model PastQuestion {
  id            String    @id
  courseId      String    @map("course_id")
  title         String
  year          Int?
  questionText  String?   @map("question_text")
  optionA       String?   @map("option_a")
  optionB       String?   @map("option_b")
  optionC       String?   @map("option_c")
  optionD       String?   @map("option_d")
  correctIndex  Int?      @map("correct_index")
  explanation   String?
  fileUrl       String?   @map("file_url")
  createdAt     DateTime? @map("created_at")
  updatedAt     DateTime? @map("updated_at")
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([courseId, year])
  @@map("past_questions")
}

// ---------------------------------------------------------------------------
// Local app tables — no auth, single implicit local user throughout.
// ---------------------------------------------------------------------------

model Settings {
  id          Int      @id @default(1)
  // Default language for one-shot AI explain requests that have no intake
  // step to ask at (QOTD, CBT review, Past-Questions "Explain with AI") —
  // "hausa" | "english". Study mode and Notes ask per-topic/per-note
  // instead (see StudySyllabus.language, Note.language) since those have a
  // real intake moment to capture the choice at.
  language    String   @default("english")
  model       String   @default("gemma4:e2b")
  // Optional user overrides for the conversational routes (lesson/chat/gloss/
  // audio) only — the "json" route's low temperature / token cap stay fixed
  // regardless (structural JSON reliability, not a length/tone preference).
  // Null means "use the per-route defaults in src/lib/ollama.ts unchanged".
  // num_ctx is intentionally NOT exposed here — see src/lib/ollama.ts.
  temperature Float?   // clamped server-side to [0.0, 1.0]
  tokenBudget Int?     @map("token_budget") // clamped server-side to [80, 500]
  // Dual model-source support: "local" (Ollama, the default/headline mode)
  // or "cloud" (Google AI Studio's Gemini API, serving a Gemma model over
  // HTTPS) — added so students whose hardware can't run a local model at
  // all still have a path in, at the cost of needing a network connection
  // and their own API key. See README for when each mode actually makes
  // sense. cloudApiKey is stored in plaintext in local SQLite: consistent
  // with this app's existing single-local-user trust model (no accounts,
  // no multi-tenant boundary, the DB file only ever lives on the student's
  // own machine) — never sent anywhere except directly to Google's API
  // from this same server process.
  modelSource String   @default("local") @map("model_source") // "local" | "cloud"
  cloudApiKey String?  @map("cloud_api_key")
  cloudModel  String?  @map("cloud_model") // null = use DEFAULT_CLOUD_MODEL in src/lib/gemini.ts
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model StudyIntake {
  id           String   @id @default(uuid())
  topic        String
  goal         String
  studyMinutes Int      @map("study_minutes")
  scenarioType String   @map("scenario_type")
  scenario     String
  createdAt    DateTime @default(now()) @map("created_at")
  syllabi      StudySyllabus[]

  @@map("study_intakes")
}

model StudySyllabus {
  id         String       @id @default(uuid())
  intakeId   String       @map("intake_id")
  topic      String
  goal       String
  unitsJson  String       @map("units_json") // serialized syllabus tree
  // Chosen at intake time (StudyIntakeForm) — "hausa" | "english". Only
  // affects the tutor explanation/chat/prereq-detection calls for this
  // syllabus; unit/subunit titles stay English regardless (see
  // syllabusGenerationSystemPrompt's doc comment for why).
  language   String       @default("english")
  createdAt  DateTime     @default(now()) @map("created_at")
  intake     StudyIntake  @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  progress   SubunitProgress[]

  @@map("study_syllabi")
}

model SubunitProgress {
  id          String        @id @default(uuid())
  syllabusId  String        @map("syllabus_id")
  subunitId   String        @map("subunit_id")
  completed   Boolean       @default(false)
  lastVisited DateTime?     @map("last_visited")
  syllabus    StudySyllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)

  @@unique([syllabusId, subunitId])
  @@map("subunit_progress")
}

model QuestionOfDay {
  id            String    @id @default(uuid())
  date          String    @unique // YYYY-MM-DD, local
  pastQuestionId String?  @map("past_question_id")
  answeredIndex Int?      @map("answered_index")
  correct       Boolean?
  answeredAt    DateTime? @map("answered_at")

  @@map("questions_of_day")
}

model Streak {
  id            Int      @id @default(1)
  currentStreak Int      @default(0) @map("current_streak")
  longestStreak Int      @default(0) @map("longest_streak")
  lastActiveDate String? @map("last_active_date") // YYYY-MM-DD

  @@map("streaks")
}

model Bookmark {
  id        String   @id @default(uuid())
  kind      String   // "past_question" | "note" | "subunit"
  refId     String   @map("ref_id")
  label     String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([kind, refId])
  @@map("bookmarks")
}

model Note {
  id        String   @id @default(uuid())
  title     String
  sourceType String  @map("source_type") // "pdf" | "image" | "text"
  rawText   String?  @map("raw_text")
  // Legacy fields from the original single-call summary+quiz shape. Left in
  // place (nullable, never written by new notes) so pre-migration notes keep
  // rendering exactly as before — see NoteDetailPage's legacy branch.
  summary   String?
  keyConcepts String? @map("key_concepts") // JSON array
  // Table-of-contents produced by the fast "json" segment-split call:
  // serialized [{segment_id,title,summary}]. Null on legacy (pre-migration)
  // notes — those have no segment structure and fall back to the legacy
  // summary/keyConcepts view instead of being force-migrated.
  segmentsJson String? @map("segments_json")
  // "quick" | "standard" | "deep" — chosen at upload time, remembered for
  // this note's on-demand segment explanation calls (numPredictOverride).
  depthPreference String @default("standard") @map("depth_preference")
  // Chosen at upload time (new-note screen) — "hausa" | "english". Only
  // affects segment explanation/chat calls for this note; segment titles
  // stay English regardless (see notesSegmentSplitSystemPrompt's doc
  // comment for why).
  language String @default("english")
  // Still populated, but now only on-demand via the deferred "Generate quiz"
  // action instead of always at creation time.
  quizJson  String?  @map("quiz_json")
  createdAt DateTime @default(now()) @map("created_at")
  segmentExplanations NoteSegmentExplanation[]

  @@map("notes")
}

// One row per generated deep explanation for a note segment. Mirrors
// SubunitProgress's shape (a related table keyed by parent id + a string
// sub-id) rather than a JSON blob on Note, since explanations are generated
// lazily and independently per segment and this codebase already has a
// proven pattern for exactly that shape.
model NoteSegmentExplanation {
  id          String   @id @default(uuid())
  noteId      String   @map("note_id")
  segmentId   String   @map("segment_id")
  explanation String
  createdAt   DateTime @default(now()) @map("created_at")
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, segmentId])
  @@map("note_segment_explanations")
}

model CbtAttempt {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  questionIds String   @map("question_ids") // JSON array
  answers     String?  // JSON map questionId -> chosenIndex
  score       Int?
  total       Int?
  startedAt   DateTime @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")

  @@map("cbt_attempts")
}
